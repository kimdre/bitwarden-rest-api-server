{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeAll"
  ],
  "dependencyDashboardLabels": ["dependencies"],
  "labels": ["dependencies"],
  "timezone": "Europe/Berlin",
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchFileNames": ["docker-compose.yml"],
      "pinDigests": false
    }
  ],
  "customManagers": [
    {
      "description": "Bitwarden CLI",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/build\\.yml$/",
        "/^dev\\.compose\\.yml$/",
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "(?m)^\\s*BW_CLI_VERSION:\\s*\\\"?(?<currentValue>[^\\\"\\s#]+)\\\"?\\s*(?:#.*)?$",
        "(?m)^\\s*-\\s*BW_CLI_VERSION=(?<currentValue>[^\\s#]+)\\s*(?:#.*)?$",
        "(?m)^\\s*ARG\\s+BW_CLI_VERSION=(?<currentValue>[^\\s#]+)\\s*(?:#.*)?$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "bitwarden/clients",
      "extractVersionTemplate": "^cli-v(?<version>.*?)$"
    }
  ]
}